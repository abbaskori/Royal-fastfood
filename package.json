{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "npm run vercel-build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present",
    "vercel-build": "npm run build -w @workspace/royal-pos && node -e \"require('fs').cpSync('artifacts/royal-pos/dist', 'dist', {recursive: true})\""
  },
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "packageManager": "npm@11.1.0",
  "overrides": {
    "esbuild": "^0.25.0",
    "drizzle-kit": {
      "esbuild": "^0.25.0"
    },
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "@esbuild-kit/esm-loader": {
      "esbuild": "^0.25.0"
    }
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
